# Dev dependencies
# Source: pyproject.toml [project.optional-dependencies.dev]
# Regenerate: uv pip compile --universal --no-emit-index-url --extra dev pyproject.toml -o requirements-dev.txt
# NOTE: This file is intentionally empty. All dependencies are declared in pyproject.toml.
# This file exists only to document the compile command and as a pre-commit trigger.
