# =============================================================================
# AStock Screener - Environment Variables Example
# =============================================================================
# Copy this file to .env and fill in actual values.
# DO NOT commit the real .env file (it is gitignored).
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
# Complete database URL (takes precedence over individual DB_* fields below)
# Example: postgresql://postgres:password@localhost:5432/astock
DATABASE_URL=

# Individual database connection fields (used when DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_NAME=astock
DB_PASSWORD=

# Connection pool settings (optional, defaults shown)
DB_CONNECTION_POOL_SIZE=10
DB_POOL_PRE_PING=true
DB_POOL_RECYCLE=1800
DB_POOL_TIMEOUT=30
DB_MAX_OVERFLOW=5

# Alembic migration database URL (falls back to DATABASE_URL if not set)
ALEMBIC_DATABASE_URL=

# -----------------------------------------------------------------------------
# Tushare API
# -----------------------------------------------------------------------------
# Required for market data. Get token from https://tushare.pro
TS_TOKEN=

# -----------------------------------------------------------------------------
# AI / LLM
# -----------------------------------------------------------------------------
# API key for LLM provider (DeepSeek, Azure, etc.)
AI_API_KEY=

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
# Strict quality gate for data persistence (true/false)
STRICT_QUALITY_GATE=true
# Strict schema validation gate (true/false)
STRICT_SCHEMA_GATE=1
# Auto-run Alembic migrations on startup (true/false/ask)
AUTO_MIGRATE=
# Debug mode - enables verbose logging and strict I18n initialization checks
DEBUG=
# Force Flet to use web server mode (true/false)
FLET_FORCE_WEB_SERVER=

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
# Test database connection (used by integration/e2e tests)
TEST_DB_HOST=localhost
TEST_DB_PORT=5432
TEST_DB_USER=postgres
TEST_DB_PASSWORD=
TEST_DB_NAME=test_astock
# CI PostgreSQL password (GitHub Actions secret, falls back to TEST_DB_PASSWORD)
CI_PG_PASSWORD=

# E2E testing flags
E2E_TESTING=
E2E_BROWSER_CHANNEL=chromium
E2E_ARTIFACT_DIR=e2e-artifacts
E2E_TIMEOUT_MULTIPLIER=1.0
E2E_HEADED=0

# Skip data consistency checks in integration tests (1/0)
SKIP_DATA_CONSISTENCY=

# -----------------------------------------------------------------------------
# Proxy (optional, for environments behind a corporate proxy)
# -----------------------------------------------------------------------------
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=
http_proxy=
https_proxy=
no_proxy=

# -----------------------------------------------------------------------------
# Other
# -----------------------------------------------------------------------------
# Custom config file path (defaults to user_settings.json in app root)
ASTOCK_CONFIG_FILE=
# Tiktoken cache directory (optional, for offline tokenization)
TIKTOKEN_CACHE_DIR=
